# Clerk authentication for the private CRM dashboard.
# This key is public by design and can be exposed to the frontend bundle.
# Add the real value in GitHub Repository Variables, not directly in this file.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_with_your_clerk_publishable_key

# Optional soft client-side allowlist for the dashboard UI.
# This is NOT a security boundary because VITE_* variables are public in Vite builds.
# Enforce real permissions in Clerk Organizations, backend APIs, Supabase RLS or another server-side layer.
VITE_ALLOWED_ADMIN_EMAILS=daniele@example.com,luciano@example.com

# Never add these to the frontend or to GitHub Pages:
# CLERK_SECRET_KEY=
# DATABASE_PASSWORD=
# SMTP_PASSWORD=
# RESEND_API_KEY=
# BREVO_API_KEY=
