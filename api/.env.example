# Railway injects PORT automatically.
PORT=3000

# PostgreSQL. Use Railway service variable reference or the Postgres DATABASE_URL.
DATABASE_URL=postgresql://user:password@host:5432/database

# Clerk backend keys. Never expose these in the frontend.
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# First admin emails allowed to bootstrap crm_users automatically.
BOOTSTRAP_ADMIN_EMAILS=luciano@example.com,daniele@example.com

# Frontend origins allowed to call this API.
ALLOWED_ORIGIN=https://lncoachmrc.github.io,http://localhost:5173

# Optional n8n integration. Leave empty until n8n is configured.
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# Set only if your Postgres connection requires SSL.
PGSSLMODE=
