# Railway injects PORT automatically.
PORT=3000

# PostgreSQL. Use Railway service variable reference or the Postgres DATABASE_URL.
DATABASE_URL=postgresql://user:password@host:5432/database

# Clerk backend keys. Never expose these in the frontend.
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# First admin emails allowed to bootstrap crm_users automatically.
BOOTSTRAP_ADMIN_EMAILS=luciano@example.com,daniele@example.com

# Frontend origins allowed to call this API.
ALLOWED_ORIGIN=https://www.eivitech.com,https://eivitech.com,http://localhost:5173

# Dual internal Resend notifications.
# Every FROM address must be verified in the Resend account that owns the matching API key.
RESEND_OWNER_API_KEY=re_owner_replace_me
RESEND_OWNER_FROM=Eivitech Website <website@notifications.eivitech.com>
RESEND_OWNER_TO=info@eivitech.com

RESEND_LUCIANO_API_KEY=re_luciano_replace_me
RESEND_LUCIANO_FROM=Eivitech Website <website@notifications.eivitech.com>
RESEND_LUCIANO_TO=lncoachmrc@gmail.com

# Confirmation sent to the email address entered in the form.
# It reuses RESEND_OWNER_API_KEY by default, so no third API key is required.
RESEND_REQUESTER_FROM=Eivitech Website <website@notifications.eivitech.com>
RESEND_REQUESTER_REPLY_TO=info@eivitech.com
PUBLIC_SITE_URL=https://www.eivitech.com

# Optional legacy fallback used only for the owner channel.
# RESEND_API_KEY=
# LEAD_NOTIFICATION_FROM=

# Webhook signing secrets will be used in the next step to track delivered/bounced/failed events.
# Keep one secret per Resend account because each account has its own webhook endpoint.
RESEND_OWNER_WEBHOOK_SECRET=whsec_owner_replace_me
RESEND_LUCIANO_WEBHOOK_SECRET=whsec_luciano_replace_me

# Optional n8n integration. Leave empty until n8n is configured.
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# Set only if your Postgres connection requires SSL.
PGSSLMODE=
